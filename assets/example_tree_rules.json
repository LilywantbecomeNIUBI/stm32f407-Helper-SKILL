  "system_focus_by_module": {
    "usart": ["drivers/system/usart"],
    "tim": ["drivers/system/delay", "drivers/system/sys"],
    "gpio": ["drivers/bsp/led"],
    "key": ["drivers/bsp/key"],
    "beep": ["drivers/bsp/beep"],
    "oled": ["drivers/bsp/oled"],
    "tft": ["drivers/bsp/lcd", "drivers/bsp/tft"],
    "touch": ["drivers/bsp/touch", "drivers/bsp/lcd"],
    "audio": ["user/app", "drivers/bsp/es8388", "drivers/bsp/wm8978"]
